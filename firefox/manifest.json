{
  "manifest_version": 3,
  "name": "WebHook Wrangler",
  "version": "1.0",
  "description": "A powerful webhook management system for sending, tracking, and analyzing URL communications with detailed history and analytics",
  "browser_specific_settings": {
    "gecko": {
      "id": "webhook-wrangler@example.com",
      "strict_min_version": "109.0"
    }
  },
  "permissions": [
    "activeTab",
    "storage",
    "notifications"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; connect-src 'self' http://* https://*;"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "scripts": ["background.js"]
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}

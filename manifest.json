{
  "manifest_version": 3,
  "name": "WebHook Wrangler",
  "version": "1.0",
  "description": "A powerful webhook management system for sending, tracking, and analyzing URL communications with detailed history and analytics",
  "permissions": [
    "activeTab",
    "storage",
    "notifications"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; connect-src 'self' http://* https://*;"
  },
  "web_accessible_resources": [{
    "resources": ["lib/*"],
    "matches": ["<all_urls>"]
  }],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}